@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="pdf-viewer-container"
     style="width: @(Width ?? "100%"); height: @(Height ?? "700px");">
    <div class="pdf-viewer-toolbar">
        @if (DisplayMode == PdfDisplayMode.SinglePage && _totalPages > 1)
        {
            <div class="pdf-viewer-nav">
                <button class="pdf-nav-btn" @onclick="PreviousPage" disabled="@(_currentPage <= 1)" title="Previous page">‹</button>
                <span class="pdf-nav-label">@_currentPage / @_totalPages</span>
                <button class="pdf-nav-btn" @onclick="NextPage" disabled="@(_currentPage >= _totalPages)" title="Next page">›</button>
            </div>
        }
        <span class="pdf-viewer-info">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <span class="text-danger">@_errorMessage</span>
            }
            else if (_totalPages > 0)
            {
                @if (DisplayMode == PdfDisplayMode.Continuous)
                {
                    <span>@_totalPages page(s) | Zoom: @ZoomPercentage | @Orientation</span>
                }
                else
                {
                    <span>Zoom: @ZoomPercentage | @Orientation</span>
                }
            }
            else if (_isLoading)
            {
                <span>Loading PDF...</span>
            }
            else
            {
                <span>No PDF loaded</span>
            }
        </span>
    </div>
    <div id="@_containerId" class="pdf-viewer-pages"></div>
</div>

@code {
    /// <summary>URL or relative path to a PDF file. Ignored when PDFData is provided.</summary>
    [Parameter]
    public string PDFFileName { get; set; } = string.Empty;

    /// <summary>Raw PDF file bytes (e.g. from an InputFile). Takes priority over PDFFileName.</summary>
    [Parameter]
    public byte[]? PDFData { get; set; }

    /// <summary>Display orientation: Portrait or Landscape.</summary>
    [Parameter]
    public PdfOrientation Orientation { get; set; } = PdfOrientation.Portrait;

    /// <summary>Zoom level for rendering.</summary>
    [Parameter]
    public PdfZoom ZoomPercentage { get; set; } = PdfZoom.Percent100;

    /// <summary>SinglePage shows one page with navigation; Continuous renders all pages in a scroll.</summary>
    [Parameter]
    public PdfDisplayMode DisplayMode { get; set; } = PdfDisplayMode.SinglePage;

    /// <summary>CSS width of the viewer container (e.g. "100%", "800px").</summary>
    [Parameter]
    public string? Width { get; set; }

    /// <summary>CSS height of the viewer container (e.g. "700px", "80vh").</summary>
    [Parameter]
    public string? Height { get; set; }

    private IJSObjectReference? _module;
    private readonly string _containerId = $"pdf-viewer-{Guid.NewGuid():N}";
    private int _totalPages;
    private int _currentPage = 1;
    private bool _isLoading;
    private bool _moduleLoaded;
    private string? _errorMessage;

    private string _prevPdf = string.Empty;
    private byte[]? _prevData;
    private PdfZoom _prevZoom;
    private PdfOrientation _prevOrientation;
    private PdfDisplayMode _prevDisplayMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/pdfViewerInterop.js");
            _moduleLoaded = true;

            if (PDFData is { Length: > 0 } || !string.IsNullOrEmpty(PDFFileName))
            {
                await LoadPdfAsync();
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_moduleLoaded)
        {
            _prevPdf = PDFFileName;
            _prevData = PDFData;
            _prevZoom = ZoomPercentage;
            _prevOrientation = Orientation;
            _prevDisplayMode = DisplayMode;
            return;
        }

        bool sourceChanged = PDFData is not null
            ? !ReferenceEquals(_prevData, PDFData)
            : _prevPdf != PDFFileName;

        if (sourceChanged)
        {
            _prevPdf = PDFFileName;
            _prevData = PDFData;
            _prevZoom = ZoomPercentage;
            _prevOrientation = Orientation;
            _prevDisplayMode = DisplayMode;
            _currentPage = 1;
            await LoadPdfAsync();
        }
        else if (_prevZoom != ZoomPercentage || _prevOrientation != Orientation || _prevDisplayMode != DisplayMode)
        {
            _prevZoom = ZoomPercentage;
            _prevOrientation = Orientation;
            _prevDisplayMode = DisplayMode;
            await UpdateViewAsync();
        }
    }

    private async Task LoadPdfAsync()
    {
        if (_module is null) return;
        if (PDFData is null or { Length: 0 } && string.IsNullOrEmpty(PDFFileName)) return;

        _isLoading = true;
        _errorMessage = null;
        _totalPages = 0;
        StateHasChanged();

        try
        {
            if (PDFData is { Length: > 0 })
            {
                _totalPages = await _module.InvokeAsync<int>(
                    "initializeFromData", _containerId, PDFData, GetZoomValue(), GetRotation(), GetDisplayMode());
            }
            else
            {
                _totalPages = await _module.InvokeAsync<int>(
                    "initialize", _containerId, PDFFileName, GetZoomValue(), GetRotation(), GetDisplayMode());
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load PDF: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
            _totalPages = 0;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task UpdateViewAsync()
    {
        if (_module is null) return;

        try
        {
            await _module.InvokeVoidAsync(
                "updateView", _containerId, GetZoomValue(), GetRotation(), GetDisplayMode());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update view: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    private async Task GoToPageAsync(int page)
    {
        if (_module is null || _totalPages == 0) return;

        var target = Math.Clamp(page, 1, _totalPages);
        if (target == _currentPage) return;

        _currentPage = target;

        try
        {
            await _module.InvokeVoidAsync("goToPage", _containerId, _currentPage);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to navigate: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }

        StateHasChanged();
    }

    private Task PreviousPage() => GoToPageAsync(_currentPage - 1);

    private Task NextPage() => GoToPageAsync(_currentPage + 1);

    private object GetZoomValue() => ZoomPercentage switch
    {
        PdfZoom.Percent25 => 0.25,
        PdfZoom.Percent50 => 0.5,
        PdfZoom.Percent100 => 1.0,
        PdfZoom.Percent150 => 1.5,
        PdfZoom.Percent200 => 2.0,
        PdfZoom.FullPage => "page-fit",
        PdfZoom.FullWidth => "page-width",
        _ => 1.0
    };

    private int GetRotation() => Orientation == PdfOrientation.Landscape ? 90 : 0;

    private string GetDisplayMode() => DisplayMode == PdfDisplayMode.SinglePage ? "single" : "continuous";

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disposePdfViewer", _containerId);
            }
            catch { /* component may already be gone */ }

            await _module.DisposeAsync();
        }
    }
}