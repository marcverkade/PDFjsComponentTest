@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="pdf-viewer-container @(CssClass ?? "")"
     style="width: @(Width ?? "100%"); @(Height is not null ? $"height: {Height};" : "")">
    <div class="pdf-viewer-toolbar">
        @if (_totalPages > 0)
        {
            @* ── Page navigation ── *@
            @if (DisplayMode == PdfDisplayMode.SinglePage && _totalPages > 1)
            {
                <div class="pdf-viewer-nav">
                    <button class="pdf-nav-btn" @onclick="FirstPage" disabled="@(_currentPage <= 1)" title="First page">⟨⟨</button>
                    <button class="pdf-nav-btn" @onclick="PreviousPage" disabled="@(_currentPage <= 1)" title="Previous page (Ctrl+←)">‹</button>
                    <span class="pdf-nav-label">@_currentPage / @_totalPages</span>
                    <button class="pdf-nav-btn" @onclick="NextPage" disabled="@(_currentPage >= _totalPages)" title="Next page (Ctrl+→)">›</button>
                    <button class="pdf-nav-btn" @onclick="LastPage" disabled="@(_currentPage >= _totalPages)" title="Last page">⟩⟩</button>
                </div>
            }
            else if (DisplayMode == PdfDisplayMode.Continuous)
            {
                <span class="pdf-toolbar-item">@_totalPages page(s)</span>
            }

            <span class="pdf-toolbar-separator">|</span>

            @* ── Zoom factor ── *@
            <span class="pdf-toolbar-item">@CurrentScaleDisplay</span>

            <span class="pdf-toolbar-separator">|</span>

            @* ── Orientation ── *@
            <span class="pdf-toolbar-item">@Orientation</span>

            <span class="pdf-toolbar-separator">|</span>

            @* ── Display mode ── *@
            <span class="pdf-toolbar-item">@(DisplayMode == PdfDisplayMode.SinglePage ? "Single" : "Continuous")</span>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <span class="text-danger">@_errorMessage</span>
        }
        else if (_isLoading)
        {
            <span class="pdf-toolbar-item">Loading PDF...</span>
        }
        else
        {
            <span class="pdf-toolbar-item">No PDF loaded</span>
        }
    </div>
    <div id="@_containerId" class="pdf-viewer-pages"></div>
</div>

@code {
    // ── Parameters ──────────────────────────────────────────────────────

    /// <summary>URL or relative path to a PDF file. Ignored when PDFData is provided.</summary>
    [Parameter]
    public string PDFFileName { get; set; } = string.Empty;

    /// <summary>Raw PDF file bytes (e.g. from an InputFile). Takes priority over PDFFileName.</summary>
    [Parameter]
    public byte[]? PDFData { get; set; }

    /// <summary>Display orientation: Portrait or Landscape.</summary>
    [Parameter]
    public PdfOrientation Orientation { get; set; } = PdfOrientation.Portrait;

    /// <summary>Zoom level for rendering.</summary>
    [Parameter]
    public PdfZoom ZoomPercentage { get; set; } = PdfZoom.Percent100;

    /// <summary>SinglePage shows one page with navigation; Continuous renders all pages in a scroll.</summary>
    [Parameter]
    public PdfDisplayMode DisplayMode { get; set; } = PdfDisplayMode.SinglePage;

    /// <summary>CSS width of the viewer container (e.g. "100%", "800px").</summary>
    [Parameter]
    public string? Width { get; set; }

    /// <summary>CSS height of the viewer container (e.g. "700px", "80vh").</summary>
    [Parameter]
    public string? Height { get; set; }

    /// <summary>Additional CSS class(es) to apply to the outer container.</summary>
    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>
    /// Maximum zoom level (0.0–10.0, where 1.0 = 100%).
    /// Clamps programmatic and gesture zoom. Default 4.0 (400%).
    /// </summary>
    [Parameter]
    public double MaxZoom { get; set; } = 4.0;

    /// <summary>
    /// Minimum zoom level (0.0–10.0, where 1.0 = 100%).
    /// Clamps programmatic and gesture zoom. Default 0.5 (50%).
    /// </summary>
    [Parameter]
    public double MinZoom { get; set; } = 0.5;

    /// <summary>
    /// Zoom step size for ZoomIn()/ZoomOut() without arguments (0.0–10.0).
    /// Default 0.25 (25%).
    /// </summary>
    [Parameter]
    public double ZoomRate { get; set; } = 0.25;

    // ── Private state ───────────────────────────────────────────────────

    private IJSObjectReference? _module;
    private DotNetObjectReference<PdfViewer>? _dotNetRef;
    private readonly string _containerId = $"pdf-viewer-{Guid.NewGuid():N}";
    private int _totalPages;
    private int _currentPage = 1;
    private bool _isLoading;
    private bool _moduleLoaded;
    private string? _errorMessage;

    /// <summary>
    /// Current effective zoom scale (0.0–10.0). Tracks the actual numeric
    /// zoom applied, including pinch/wheel overrides. Null until first render.
    /// </summary>
    private double? _currentScale;

    /// <summary>
    /// Formatted display string for the current zoom factor.
    /// Shows the actual effective percentage (e.g. "Zoom: 125%"),
    /// reflecting pinch, wheel, and programmatic zoom changes.
    /// </summary>
    private string CurrentScaleDisplay =>
        _currentScale.HasValue
            ? $"Zoom: {_currentScale.Value * 100:F0}%"
            : $"Zoom: {ZoomPercentage}";

    private string _prevPdf = string.Empty;
    private byte[]? _prevData;
    private PdfZoom _prevZoom;
    private PdfOrientation _prevOrientation;
    private PdfDisplayMode _prevDisplayMode;

    // ── Lifecycle ───────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/pdfViewerInterop.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            _moduleLoaded = true;

            if (PDFData is { Length: > 0 } || !string.IsNullOrEmpty(PDFFileName))
            {
                await LoadPdfAsync();
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_moduleLoaded)
        {
            _prevPdf = PDFFileName;
            _prevData = PDFData;
            _prevZoom = ZoomPercentage;
            _prevOrientation = Orientation;
            _prevDisplayMode = DisplayMode;
            return;
        }

        bool sourceChanged = PDFData is not null
            ? !ReferenceEquals(_prevData, PDFData)
            : _prevPdf != PDFFileName;

        if (sourceChanged)
        {
            _prevPdf = PDFFileName;
            _prevData = PDFData;
            _prevZoom = ZoomPercentage;
            _prevOrientation = Orientation;
            _prevDisplayMode = DisplayMode;
            _currentPage = 1;
            await LoadPdfAsync();
        }
        else if (_prevZoom != ZoomPercentage || _prevOrientation != Orientation || _prevDisplayMode != DisplayMode)
        {
            _prevZoom = ZoomPercentage;
            _prevOrientation = Orientation;
            _prevDisplayMode = DisplayMode;
            await UpdateViewAsync();
        }
    }

    // ── PDF loading ─────────────────────────────────────────────────────

    private async Task LoadPdfAsync()
    {
        if (_module is null) return;
        if (PDFData is null or { Length: 0 } && string.IsNullOrEmpty(PDFFileName)) return;

        _isLoading = true;
        _errorMessage = null;
        _totalPages = 0;
        StateHasChanged();

        try
        {
            if (PDFData is { Length: > 0 })
            {
                _totalPages = await _module.InvokeAsync<int>(
                    "initializeFromData", _containerId, PDFData,
                    GetZoomValue(), GetRotation(), GetDisplayMode(),
                    _dotNetRef, MinZoom, MaxZoom);
            }
            else
            {
                _totalPages = await _module.InvokeAsync<int>(
                    "initialize", _containerId, PDFFileName,
                    GetZoomValue(), GetRotation(), GetDisplayMode(),
                    _dotNetRef, MinZoom, MaxZoom);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load PDF: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
            _totalPages = 0;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ── JS → Blazor callbacks ───────────────────────────────────────────

    /// <summary>
    /// Called from JavaScript when the user navigates pages via keyboard (Ctrl+Arrow)
    /// or swipe gesture. Updates the Blazor-side page counter so the toolbar stays in sync.
    /// </summary>
    [JSInvokable]
    public void OnPageChangedFromJs(int newPage)
    {
        _currentPage = newPage;
        StateHasChanged();
    }

    /// <summary>
    /// Called from JavaScript after each render to report the effective numeric scale.
    /// Keeps the C# side in sync with pinch/wheel zoom changes and updates the toolbar.
    /// </summary>
    [JSInvokable]
    public void OnScaleChangedFromJs(double scale)
    {
        _currentScale = scale;
        StateHasChanged();
    }

    // ── View updates ────────────────────────────────────────────────────

    private async Task UpdateViewAsync()
    {
        if (_module is null) return;

        try
        {
            await _module.InvokeVoidAsync(
                "updateView", _containerId, GetZoomValue(), GetRotation(), GetDisplayMode());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update view: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    private async Task GoToPageAsync(int page)
    {
        if (_module is null || _totalPages == 0) return;

        var target = Math.Clamp(page, 1, _totalPages);
        if (target == _currentPage) return;

        _currentPage = target;

        try
        {
            await _module.InvokeVoidAsync("goToPage", _containerId, _currentPage);

            // Refocus the PDF container so arrow keys keep working
            // after clicking a toolbar button (which steals focus)
            await _module.InvokeVoidAsync("focusContainer", _containerId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to navigate: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }

        StateHasChanged();
    }

    private Task FirstPage() => GoToPageAsync(1);

    private Task PreviousPage() => GoToPageAsync(_currentPage - 1);

    private Task NextPage() => GoToPageAsync(_currentPage + 1);

    private Task LastPage() => GoToPageAsync(_totalPages);

    // ── Public methods (accessible via @ref) ────────────────────────────

    /// <summary>
    /// The current effective zoom scale as a ratio (e.g. 1.25 = 125%).
    /// Reflects the actual zoom including pinch/wheel overrides.
    /// Null until the first render completes.
    /// </summary>
    public double? CurrentScale => _currentScale;

    /// <summary>Zoom in by the configured <see cref="ZoomRate"/>.</summary>
    public Task ZoomInAsync() => ZoomInAsync((decimal)ZoomRate);

    /// <summary>Zoom in by a custom amount (0.0–10.0).</summary>
    public async Task ZoomInAsync(decimal zoomAmount)
    {
        if (_module is null || _totalPages == 0) return;

        try
        {
            await _module.InvokeVoidAsync(
                "zoomBy", _containerId, (double)zoomAmount, MinZoom, MaxZoom);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Zoom in failed: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    /// <summary>Zoom out by the configured <see cref="ZoomRate"/>.</summary>
    public Task ZoomOutAsync() => ZoomOutAsync((decimal)ZoomRate);

    /// <summary>Zoom out by a custom amount (0.0–10.0).</summary>
    public async Task ZoomOutAsync(decimal zoomAmount)
    {
        if (_module is null || _totalPages == 0) return;

        try
        {
            await _module.InvokeVoidAsync(
                "zoomBy", _containerId, -(double)zoomAmount, MinZoom, MaxZoom);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Zoom out failed: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    /// <summary>
    /// Reset zoom to a specific mode, clearing any pinch/wheel zoom override.
    /// Accepts a <see cref="PdfZoom"/> value to reset to (e.g. PdfZoom.FullWidth).
    /// </summary>
    public async Task SetZoomAsync(PdfZoom zoom)
    {
        if (_module is null || _totalPages == 0) return;

        try
        {
            // Convert the enum to the JS zoom value format
            var zoomValue = zoom switch
            {
                PdfZoom.Percent25 => (object)0.25,
                PdfZoom.Percent50 => 0.5,
                PdfZoom.Percent100 => 1.0,
                PdfZoom.Percent150 => 1.5,
                PdfZoom.Percent200 => 2.0,
                PdfZoom.FullPage => "page-fit",
                PdfZoom.FullWidth => "page-width",
                _ => 1.0
            };
            await _module.InvokeVoidAsync("resetZoom", _containerId, zoomValue);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Reset zoom failed: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    /// <summary>Print the entire PDF document.</summary>
    public async Task PrintAsync()
    {
        if (_module is null || _totalPages == 0) return;

        try
        {
            await _module.InvokeVoidAsync("printPdf", _containerId, 1, _totalPages);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Print failed: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    /// <summary>Print a range of pages (1-based, inclusive).</summary>
    public async Task PrintAsync(int pageStart, int pageEnd)
    {
        if (_module is null || _totalPages == 0) return;

        var start = Math.Clamp(pageStart, 1, _totalPages);
        var end = Math.Clamp(pageEnd, start, _totalPages);

        try
        {
            await _module.InvokeVoidAsync("printPdf", _containerId, start, end);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Print failed: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    /// <summary>
    /// Search for text in the PDF and highlight all occurrences.
    /// Pass null or empty string to clear highlights.
    /// </summary>
    public async Task SearchAsync(string? searchText)
    {
        if (_module is null || _totalPages == 0) return;

        try
        {
            await _module.InvokeVoidAsync("searchText", _containerId, searchText ?? "");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Search failed: {ex.Message}";
            Console.WriteLine($"PdfViewer error: {ex}");
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────────

    private object GetZoomValue() => ZoomPercentage switch
    {
        PdfZoom.Percent25 => 0.25,
        PdfZoom.Percent50 => 0.5,
        PdfZoom.Percent100 => 1.0,
        PdfZoom.Percent150 => 1.5,
        PdfZoom.Percent200 => 2.0,
        PdfZoom.FullPage => "page-fit",
        PdfZoom.FullWidth => "page-width",
        _ => 1.0
    };

    private int GetRotation() => Orientation == PdfOrientation.Landscape ? 90 : 0;

    private string GetDisplayMode() => DisplayMode == PdfDisplayMode.SinglePage ? "single" : "continuous";

    // ── Dispose ──────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disposePdfViewer", _containerId);
            }
            catch { /* component may already be gone */ }

            await _module.DisposeAsync();
        }

        // Dispose the .NET object reference to prevent memory leaks
        _dotNetRef?.Dispose();
    }
}