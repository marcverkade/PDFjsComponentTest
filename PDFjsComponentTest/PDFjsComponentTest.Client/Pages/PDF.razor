@page "/pdfviewer"
@rendermode InteractiveWebAssembly

<TelerikRootComponent>

<PageTitle>PDF Viewer</PageTitle>

<h1>PDF Viewer</h1>

@if (!_isInteractive)
{
    <div class="border rounded p-5 text-center text-muted" style="height: 200px; display: flex; align-items: center; justify-content: center; background: #f8f9fa;">
        <span>Loading WebAssembly runtime...</span>
    </div>
}
else
{
    <div class="mb-3 d-flex align-items-end gap-3 flex-wrap">
        <div>
            <label class="form-label">Select a PDF file:</label>
            <InputFile OnChange="@OnFileSelected" accept=".pdf" class="form-control" style="max-width: 400px;"
                       tabindex="-1" />
            @if (!string.IsNullOrEmpty(fileErrorMessage))
            {
                <small class="text-danger">@fileErrorMessage</small>
            }
        </div>

        <div>
            <label class="form-label">Zoom:</label>
            <select class="form-select w-auto" @bind="selectedZoom" tabindex="-1">
                <option value="@PdfZoom.Percent25">25%</option>
                <option value="@PdfZoom.Percent50">50%</option>
                <option value="@PdfZoom.Percent100">100%</option>
                <option value="@PdfZoom.Percent150">150%</option>
                <option value="@PdfZoom.Percent200">200%</option>
                <option value="@PdfZoom.FullPage">Full Page</option>
                <option value="@PdfZoom.FullWidth">Full Width</option>
            </select>
        </div>

        <div>
            <label class="form-label">Orientation:</label>
            <select class="form-select w-auto" @bind="selectedOrientation" tabindex="-1">
                <option value="@PdfOrientation.Portrait">Portrait</option>
                <option value="@PdfOrientation.Landscape">Landscape</option>
            </select>
        </div>

        <div>
            <label class="form-label">Display:</label>
            <select class="form-select w-auto" @bind="selectedDisplayMode" tabindex="-1">
                <option value="@PdfDisplayMode.SinglePage">Single Page</option>
                <option value="@PdfDisplayMode.Continuous">Continuous</option>
            </select>
        </div>

        @* ── Search: inline next to Display for compact layout ── *@
        <div>
            <label class="form-label">Search:</label>
            <div class="input-group input-group-sm" style="width: 300px;">
                <input type="text" class="form-control" @bind="searchQuery" @bind:event="oninput"
                       placeholder="Search text in PDF..." @onkeydown="OnSearchKeyDown" tabindex="-1" />
                <button class="btn btn-outline-success" @onclick="OnSearch" title="Search and highlight"
                        tabindex="-1">
                    🔎
                </button>
                <button class="btn btn-outline-secondary" @onclick="OnClearSearch" title="Clear highlights"
                        tabindex="-1">
                    ✕
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(selectedFileName))
    {
        <p class="text-muted mb-2">
            <strong>Loaded:</strong> @selectedFileName (@FormatFileSize(selectedFileSize))
        </p>
    }

    @* ── Viewer action buttons (shown when any PDF is loaded) ── *@
    @if (pdfBytes is not null || !string.IsNullOrEmpty(DefaultPdfUrl))
    {
        <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
            @* Zoom controls — uses the custom zoom step amount *@
            <button class="btn btn-outline-secondary btn-sm" @onclick="OnZoomOut" title="Zoom out by custom amount"
                    tabindex="-1">
                🔍− Zoom Out
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="OnZoomIn" title="Zoom in by custom amount"
                    tabindex="-1">
                🔍+ Zoom In
            </button>

            <button class="btn btn-outline-warning btn-sm" @onclick="OnResetZoom" title="Reset zoom to full width"
                    tabindex="-1">
                ↔ Fit Width
            </button>

            <span class="text-muted mx-1">|</span>

            @* Custom zoom amount *@
            <div class="input-group input-group-sm" style="width: 200px;">
                <input type="number" class="form-control" @bind="customZoomAmount"
                       min="0.05" max="5.0" step="0.05" placeholder="Amount" tabindex="-1" />
                <button class="btn btn-outline-secondary" @onclick="IncreaseZoomStep" title="Increase zoom step by 0.05"
                        tabindex="-1">+</button>
                <button class="btn btn-outline-secondary" @onclick="DecreaseZoomStep" title="Decrease zoom step by 0.05"
                        tabindex="-1">−</button>
            </div>

            <span class="text-muted mx-1">|</span>

            @* Print controls — disabled when printing is prevented *@
            <button class="btn btn-outline-primary btn-sm" @onclick="OnPrintAll" disabled="@preventPrinting"
                    title="@(preventPrinting ? "Printing is disabled" : "Print all pages")" tabindex="-1">
                🖨 Print All
            </button>

            <div class="input-group input-group-sm" style="width: 250px;">
                <input type="number" class="form-control" @bind="printStartPage" min="1" placeholder="From"
                       disabled="@preventPrinting" tabindex="-1" />
                <input type="number" class="form-control" @bind="printEndPage" min="1" placeholder="To"
                       disabled="@preventPrinting" tabindex="-1" />
                <button class="btn btn-outline-primary" @onclick="OnPrintRange" disabled="@preventPrinting"
                        title="@(preventPrinting ? "Printing is disabled" : "Print page range")" tabindex="-1">
                    🖨 Range
                </button>
            </div>

            <span class="text-muted mx-1">|</span>

            @* Download controls — disabled when download is prevented *@
            <button class="btn btn-outline-success btn-sm" @onclick="OnDownloadAll" disabled="@preventDownload"
                    title="@(preventDownload ? "Download is disabled" : "Download entire PDF")" tabindex="-1">
                💾 Download All
            </button>
            <button class="btn btn-outline-success btn-sm" @onclick="OnDownloadCurrentPage" disabled="@preventDownload"
                    title="@(preventDownload ? "Download is disabled" : "Download current page as PNG")" tabindex="-1">
                💾 Current Page
            </button>

            <span class="text-muted mx-1">|</span>

            @* Protection toggle buttons *@
            <button class="btn btn-sm @(preventDownload ? "btn-danger" : "btn-outline-danger")"
                    @onclick="TogglePreventDownload"
                    title="@(preventDownload ? "Download protection ON — click to disable" : "Download protection OFF — click to enable")"
                    tabindex="-1">
                @(preventDownload ? "🔒 Download Off" : "🔓 Download On")
            </button>
            <button class="btn btn-sm @(preventPrinting ? "btn-danger" : "btn-outline-danger")"
                    @onclick="TogglePreventPrinting"
                    title="@(preventPrinting ? "Print protection ON — click to disable" : "Print protection OFF — click to enable")"
                    tabindex="-1">
                @(preventPrinting ? "🔒 Print Off" : "🔓 Print On")
            </button>
        </div>

        @* ── PDF Viewer: use uploaded bytes if available, otherwise the default URL ── *@
        @if (pdfBytes is not null)
        {
            <PdfViewer @ref="pdfViewerRef"
                       PDFData="@pdfBytes"
                       ZoomPercentage="@selectedZoom"
                       Orientation="@selectedOrientation"
                       DisplayMode="@selectedDisplayMode"
                       PreventDownload="@preventDownload"
                       PreventPrinting="@preventPrinting"
                       MinZoom="0.1"
                       MaxZoom="5.0"
                       ZoomRate="0.25"
                       Height="70vh" />
        }
        else
        {
            <PdfViewer @ref="pdfViewerRef"
                       PDFFileName="@DefaultPdfUrl"
                       ZoomPercentage="@selectedZoom"
                       Orientation="@selectedOrientation"
                       DisplayMode="@selectedDisplayMode"
                       PreventDownload="@preventDownload"
                       PreventPrinting="@preventPrinting"
                       MinZoom="0.1"
                       MaxZoom="5.0"
                       ZoomRate="0.25"
                       Height="70vh" />
        }
    }
}

</TelerikRootComponent>

@code {
    // ── Default PDF loaded automatically on page load ──
    private const string DefaultPdfUrl = "pdf/20230302.pdf";

    // Tracks whether the WASM runtime is ready and event handlers are wired up.
    // Prevents the user from interacting with controls that don't work yet.
    private bool _isInteractive;

    private PdfZoom selectedZoom = PdfZoom.FullWidth;
    private PdfOrientation selectedOrientation = PdfOrientation.Portrait;
    private PdfDisplayMode selectedDisplayMode = PdfDisplayMode.SinglePage;

    private byte[]? pdfBytes;
    private string? selectedFileName;
    private long selectedFileSize;

    private const long MaxFileSize = 50 * 1024 * 1024; // 50 MB

    // ── PdfViewer @ref for calling public methods ──
    private PdfViewer? pdfViewerRef;

    // ── Zoom controls state ──
    private double customZoomAmount = 0.25;

    // ── Print controls state ──
    private int printStartPage = 1;
    private int printEndPage = 1;

    // ── Search state ──
    private string searchQuery = string.Empty;

    // ── Error/info message for file selection ──
    private string? fileErrorMessage;

    // ── Protection toggles ──
    private bool preventDownload;
    private bool preventPrinting;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // OnAfterRender only fires once the WASM runtime is active
            // and the component is truly interactive.
            _isInteractive = true;
            StateHasChanged();
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file is null) return;

        // Clear any previous error
        fileErrorMessage = null;

        if (!file.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase)
            && !file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
        {
            fileErrorMessage = "Please select a valid PDF file.";
            return;
        }

        selectedFileName = file.Name;
        selectedFileSize = file.Size;

        await using var stream = file.OpenReadStream(maxAllowedSize: MaxFileSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        pdfBytes = ms.ToArray();
    }

    // ── Zoom button handlers ──

    private async Task OnZoomIn()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.ZoomInAsync((decimal)customZoomAmount);
    }

    private async Task OnZoomOut()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.ZoomOutAsync((decimal)customZoomAmount);
    }

    /// <summary>Reset zoom to full width, clearing any pinch/wheel override.</summary>
    private async Task OnResetZoom()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.SetZoomAsync(PdfZoom.FullWidth);
    }

    // ── Print button handlers ──

    private async Task OnPrintAll()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.PrintAsync();
    }

    private async Task OnPrintRange()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.PrintAsync(printStartPage, printEndPage);
    }

    // ── Search handlers ──

    private async Task OnSearch()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.SearchAsync(searchQuery);
    }

    private async Task OnClearSearch()
    {
        searchQuery = string.Empty;
        if (pdfViewerRef is not null)
            await pdfViewerRef.SearchAsync(null);
    }

    /// <summary>Trigger search on Enter key press.</summary>
    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await OnSearch();
    }

    // ── Download button handlers ──

    private async Task OnDownloadAll()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.DownloadAllAsync(selectedFileName ?? "document.pdf");
    }

    private async Task OnDownloadCurrentPage()
    {
        if (pdfViewerRef is not null)
            await pdfViewerRef.DownloadCurrentPageAsync();
    }

    // ── Protection toggle handlers ──

    private void TogglePreventDownload()
    {
        preventDownload = !preventDownload;
    }

    private void TogglePreventPrinting()
    {
        preventPrinting = !preventPrinting;
    }

    // ── Helpers ──

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";
        if (bytes < 1024 * 1024)
            return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    /// <summary>Increase the custom zoom step amount by 0.05.</summary>
    private void IncreaseZoomStep()
    {
        customZoomAmount = Math.Min(5.0, Math.Round(customZoomAmount + 0.05, 2));
    }

    /// <summary>Decrease the custom zoom step amount by 0.05.</summary>
    private void DecreaseZoomStep()
    {
        customZoomAmount = Math.Max(0.05, Math.Round(customZoomAmount - 0.05, 2));
    }
}
