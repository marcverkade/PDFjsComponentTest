<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["PDFjsComponentTest.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />

</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>

    @* ── Block iOS Safari browser zoom while allowing PDF viewer pinch ── *@
    <script>
        (function () {
            // Block multi-touch zoom outside the PDF viewer
            document.addEventListener('touchmove', function (e) {
                if (e.touches.length > 1 && !e.target.closest('.pdf-viewer-pages')) {
                    e.preventDefault();
                }
            }, { passive: false });

            // Block Safari-specific gesture events (fires before touchmove)
            document.addEventListener('gesturestart', function (e) {
                if (!e.target.closest('.pdf-viewer-pages')) e.preventDefault();
            }, { passive: false });

            document.addEventListener('gesturechange', function (e) {
                if (!e.target.closest('.pdf-viewer-pages')) e.preventDefault();
            }, { passive: false });

            // Block double-tap-to-zoom outside the PDF viewer
            var lastTouchEnd = 0;
            document.addEventListener('touchend', function (e) {
                if (e.target.closest('.pdf-viewer-pages')) return;
                var now = Date.now();
                if (now - lastTouchEnd <= 300) e.preventDefault();
                lastTouchEnd = now;
            }, { passive: false });
        })();
    </script>
</body>

</html>
